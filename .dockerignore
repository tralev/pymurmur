# Docker build exclusions — prevents host artifacts from entering the image.
# The Docker build context is the project root (docker build -f ci/Dockerfile .).

# Prevent host output artifacts from polluting the image
output/

# Python caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Coverage
.coverage
htmlcov/

# Git
.git/
